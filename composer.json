{
    "name": "adeel3330/insight-guard",
    "description": "All-in-one Laravel security, performance, and database optimization analyzer.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Adeel3330\\InsightGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Adeel3330\\InsightGuard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Adeel3330\\InsightGuard\\Providers\\InsightGuardServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1 | ^8.2 | ^8.3 | ^8.4 | ^8.5",
        "illuminate/support": "^10 | ^11 | ^12 | ^13",
        "barryvdh/laravel-dompdf": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10|^11",
        "larastan/larastan": "^3.0",
        "squizlabs/php_codesniffer": "^3.5"
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "cs": "phpcs --standard=PSR12 src/ tests/",
        "cs-fix": "phpcbf --standard=PSR12 src/ tests/",
        "stan": "vendor/bin/phpstan analyse src/ tests/ --level max"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}